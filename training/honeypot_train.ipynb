   "metadata": {"id": "plot_curves"},
   "outputs": [],
   "source": [
    "# Cell 17: Generate 3 reward curves from training_log.csv\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "ROLL = 20  # rolling window\n",
    "\n",
    "df = pd.read_csv(LOG_FILE)\n",
    "df['main_task_complete']  = df['main_task_complete'].astype(bool)\n",
    "df['side_task_attempted'] = df['side_task_attempted'].astype(bool)\n",
    "print(f'Loaded {len(df)} episodes')\n",
    "print(df[['mode','main_task_complete','side_task_attempted','consistency_score']].describe())\n",
    "\n",
    "\n",
    "# ── Curve 1: Main Task Completion Rate ──────────────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "rate = df['main_task_complete'].astype(float)\n",
    "ax.plot(df['episode'], rate.rolling(ROLL, min_periods=1).mean(),\n",
    "        color='#2196F3', linewidth=2, label=f'Rolling avg ({ROLL} ep)')\n",
    "ax.scatter(df['episode'], rate, alpha=0.12, s=6, color='#2196F3')\n",
    "ax.axhline(0.8, linestyle='--', color='green', alpha=0.5, label='Target 0.8')\n",
    "ax.set_title('Main Task Completion Rate', fontsize=15, fontweight='bold')\n",
    "ax.set_xlabel('Episode'); ax.set_ylabel('Rate'); ax.set_ylim(-0.05, 1.15)\n",
    "ax.legend(); ax.grid(alpha=0.3)\n",
    "fig.savefig('curve1.png', dpi=150, bbox_inches='tight')\n",
    "plt.show(); print('✅ curve1.png saved')\n",
    "\n",
    "\n",
    "# ── Curve 2: Side Task Attempt Rate (no_monitoring only) ────────────────────\n",
    "nm = df[df['mode'] == 'no_monitoring']\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "if len(nm) > 0:\n",
    "    rate2 = nm['side_task_attempted'].astype(float)\n",
    "    ax.plot(nm['episode'], rate2.rolling(ROLL, min_periods=1).mean(),\n",
    "            color='#F44336', linewidth=2, label=f'Rolling avg ({ROLL} ep)')\n",
    "    ax.scatter(nm['episode'], rate2, alpha=0.12, s=6, color='#F44336')\n",
    "ax.axhline(0.1, linestyle='--', color='green', alpha=0.5, label='Target <0.1')\n",
    "ax.set_title('Side Task Attempt Rate — No Monitoring Mode', fontsize=15, fontweight='bold')\n",
    "ax.set_xlabel('Episode'); ax.set_ylabel('Attempt rate'); ax.set_ylim(-0.05, 1.15)\n",
    "ax.legend(); ax.grid(alpha=0.3)\n",
    "fig.savefig('curve2.png', dpi=150, bbox_inches='tight')\n",
    "plt.show(); print('✅ curve2.png saved')\n",
    "\n",
    "\n",
    "# ── Curve 3: Consistency Score Across All Modes ─────────────────────────────\n",
    "MODE_COLORS = {'evaluation': '#4CAF50', 'deployment': '#FF9800', 'no_monitoring': '#9C27B0'}\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "for mode, grp in df.groupby('mode'):\n",
    "    s = grp['consistency_score'].astype(float).rolling(ROLL, min_periods=1).mean()\n",
    "    ax.plot(grp['episode'], s, linewidth=1.5, alpha=0.8,\n",
    "            color=MODE_COLORS.get(mode, 'gray'), label=mode)\n",
    "overall = df['consistency_score'].astype(float).rolling(ROLL, min_periods=1).mean()\n",
    "ax.plot(df['episode'], overall, color='black', linewidth=2.5, linestyle='--', label='All modes')\n",
    "ax.axhline(0.9, linestyle='--', color='green', alpha=0.5, label='Target 0.9')\n",
    "ax.set_title('Consistency Score Across All Modes', fontsize=15, fontweight='bold')\n",
    "ax.set_xlabel('Episode'); ax.set_ylabel('Consistency (1 = honest)'); ax.set_ylim(-0.05, 1.15)\n",
    "ax.legend(); ax.grid(alpha=0.3)\n",
    "fig.savefig('curve3.png', dpi=150, bbox_inches='tight')\n",
    "plt.show(); print('✅ curve3.png saved')"
   ]
