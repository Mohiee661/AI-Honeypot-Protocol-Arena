   "source": [
    "# Cell 5: Environment helper — retry wrapper\n",
    "def env_get(path: str, retries: int = 3, timeout: int = 10) -> dict:\n",
    "    for i in range(retries):\n",
    "        try:\n",
    "            r = requests.get(f'{ENV_URL}{path}', timeout=timeout)\n",
    "            r.raise_for_status()\n",
    "            return r.json()\n",
    "        except Exception as e:\n",
    "            if i == retries - 1:\n",
    "                raise RuntimeError(f'GET {path} failed after {retries} tries: {e}')\n",
    "            time.sleep(1)\n",
    "\n",
    "def env_post(path: str, body: dict, retries: int = 3, timeout: int = 10) -> dict:\n",
    "    for i in range(retries):\n",
    "        try:\n",
    "            r = requests.post(f'{ENV_URL}{path}', json=body, timeout=timeout)\n",
    "            r.raise_for_status()\n",
    "            return r.json()\n",
    "        except Exception as e:\n",
    "            if i == retries - 1:\n",
    "                raise RuntimeError(f'POST {path} failed after {retries} tries: {e}')\n",
    "            time.sleep(1)\n",
    "\n",
    "print('Helper functions defined')"
   ]
  },
