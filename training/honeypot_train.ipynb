   "source": [
    "## Phase 4 — GRPO Training\n",
    "\n",
    "**Before running the full training:**\n",
    "1. Switch `ENV_URL = ENV_URL_SPACES` in Cell 4 and re-run it\n",
    "2. Get the HF Spaces URL from Person A\n",
    "3. Run the smoke test (50 steps) first — confirm no crashes\n",
    "4. Then run full training (500 steps, ~90 min)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "grpo_utils"},
   "outputs": [],
   "source": [
    "# Cell 12: GRPO update function + CSV logger\n",
    "import csv, os\n",
    "\n",
    "LOG_FIELDS = [\n",
    "    'episode', 'step', 'total_reward',\n",
    "    'main_task_complete', 'side_task_attempted', 'mode', 'consistency_score'\n",
    "]\n",
    "\n",
    "def init_log(path: str) -> None:\n",
    "    with open(path, 'w', newline='') as f:\n",
    "        csv.DictWriter(f, fieldnames=LOG_FIELDS).writeheader()\n",
    "\n",
    "def append_log(path: str, row: dict) -> None:\n",
    "    with open(path, 'a', newline='') as f:\n",
    "        csv.DictWriter(f, fieldnames=LOG_FIELDS).writerow(row)\n",
    "\n",
    "\n",
    "def compute_action_log_probs(\n",
    "    prompt_ids: torch.Tensor,\n",
    "    action_ids: torch.Tensor,\n",
    ") -> torch.Tensor:\n",
    "    \"\"\"\n",
    "    Forward pass with gradients; returns scalar log-prob of action tokens.\n",
    "    prompt_ids  : (1, n_prompt)\n",
    "    action_ids  : (1, n_action)\n",
    "    \"\"\"\n",
    "    full_ids = torch.cat([prompt_ids, action_ids], dim=1).to(model.device)\n",
    "    n_prompt = prompt_ids.shape[1]\n",
    "\n",
    "    outputs = model(input_ids=full_ids)\n",
    "    # logits[i] → prediction for token i+1\n",
    "    # action logits span positions [n_prompt-1 : -1]\n",
    "    action_logits = outputs.logits[:, n_prompt - 1 : -1, :]   # (1, n_action, vocab)\n",
    "    log_probs     = F.log_softmax(action_logits, dim=-1)\n",
    "\n",
    "    act = action_ids.to(model.device)                          # (1, n_action)\n",
    "    if act.shape[1] == 0:\n",
    "        return torch.tensor(0.0, device=model.device, requires_grad=True)\n",
    "\n",
    "    token_lp = log_probs.gather(2, act.unsqueeze(-1)).squeeze(-1)  # (1, n_action)\n",
    "    return token_lp.sum()\n",
    "\n",
    "\n",
    "def grpo_update(\n",
    "    optimizer: AdamW,\n",
    "    episode_batch: list,\n",
    ") -> float:\n",
    "    \"\"\"\n",
    "    episode_batch: list of {'trajectory': [...], 'reward': float}\n",
    "    Each trajectory step has prompt_ids and action_ids.\n",
    "    \"\"\"\n",
    "    model.train()\n",
    "\n",
    "    rewards   = torch.tensor([ep['reward'] for ep in episode_batch], dtype=torch.float32)\n",
    "    if rewards.std() > 1e-8:\n",
    "        advantages = (rewards - rewards.mean()) / (rewards.std() + 1e-8)\n",
    "    else:\n",
    "        advantages = rewards - rewards.mean()\n",
    "\n",
    "    optimizer.zero_grad()\n",
    "    total_loss = torch.tensor(0.0, device=model.device)\n",
    "\n",
    "    for ep, adv in zip(episode_batch, advantages):\n",
    "        ep_loss = torch.tensor(0.0, device=model.device)\n",
    "        n = len(ep['trajectory'])\n",
    "        for step in ep['trajectory']:\n",
    "            lp       = compute_action_log_probs(step['prompt_ids'], step['action_ids'])\n",
    "            ep_loss  = ep_loss + (-(adv.to(model.device) * lp))\n",
    "        total_loss = total_loss + ep_loss / max(n, 1)\n",
    "\n",
    "    loss = total_loss / len(episode_batch)\n",
    "    loss.backward()\n",
    "    torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "    optimizer.step()\n",
    "\n",
    "    torch.cuda.empty_cache()\n",
    "    return loss.item()\n",
    "\n",
    "print('GRPO utilities defined')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "training_loop_fn"},
   "outputs": [],
   "source": [
    "# Cell 13: Training loop function\n",
    "\n",
    "def training_loop(\n",
    "    num_steps: int     = NUM_STEPS,\n",
    "    batch_size: int    = BATCH_SIZE,\n",
    "    log_file: str      = LOG_FILE,\n",
    "    save_every: int    = SAVE_EVERY,\n",
    "    start_step: int    = 0,\n",
    "    start_episode: int = 0,\n",
    ") -> None:\n",
    "    optimizer = AdamW(model.parameters(), lr=LR)\n",
    "    init_log(log_file)\n",
    "\n",
    "    episode_counter = start_episode\n",
    "    step_t0         = time.time()\n",
    "\n",
    "    for step in range(start_step, start_step + num_steps):\n",
    "        batch = []\n",
    "\n",
    "        for b in range(batch_size):\n",
    "            seed          = step * batch_size + b\n",
    "            traj, reward, info = run_episode(seed)\n",
    "\n",
    "            batch.append({'trajectory': traj, 'reward': reward})\n",
    "\n",
    "            consistency = 0.0 if info.get('side_task_attempted') else 1.0\n",
    "            append_log(log_file, {\n",
    "                'episode'           : episode_counter,\n",
    "                'step'              : step,\n",
    "                'total_reward'      : reward,\n",
    "                'main_task_complete': info.get('main_task_complete', False),\n",
    "                'side_task_attempted': info.get('side_task_attempted', False),\n",
    "                'mode'              : info.get('mode', 'unknown'),\n",
    "                'consistency_score' : consistency,\n",
    "            })\n",
    "            episode_counter += 1\n",
    "\n",
    "        loss = grpo_update(optimizer, batch)\n",
    "\n",
    "        if step % LOG_EVERY == 0 or step == start_step:\n",
    "            avg_reward = sum(ep['reward'] for ep in batch) / len(batch)\n",
    "            elapsed    = time.time() - step_t0\n",
    "            print(\n",
    "                f'Step {step:4d}/{start_step + num_steps} | '\n",
    "                f'loss={loss:+.4f} | '\n",
    "                f'avg_reward={avg_reward:+.3f} | '\n",
    "                f'elapsed={elapsed/60:.1f} min'\n",
    "            )\n",
    "\n",
    "        if (step + 1) % save_every == 0:\n",
    "            ckpt = os.path.join(OUTPUT_DIR, f'checkpoint-{step+1}')\n",
    "            model.save_pretrained(ckpt)\n",
    "            tokenizer.save_pretrained(ckpt)\n",
    "            print(f'  💾 Checkpoint saved → {ckpt}')\n",
    "\n",
    "    print(f'\\n✅ Training complete — {episode_counter} episodes logged to {log_file}')\n",
    "\n",
    "print('training_loop() defined')"
   ]
